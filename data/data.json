<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>وهج الماسة — أداة تحديث التقارير الشهرية</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Tajawal',sans-serif;background:#0f1117;color:#e8eaf0;min-height:100vh;padding:2rem 1rem}
.wrap{max-width:680px;margin:0 auto;display:flex;flex-direction:column;gap:1.25rem}

/* HEADER */
.header{display:flex;align-items:center;gap:14px;padding-bottom:1rem;border-bottom:1px solid #323648}
.diamond{width:44px;height:44px;background:linear-gradient(135deg,#b8860b,#ffd700,#b8860b);clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%);flex-shrink:0}
.header h1{font-size:17px;font-weight:800}
.header p{font-size:11px;color:#8b90a8;margin-top:2px}

/* STEPS */
.steps{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.step{background:#1c1f2b;border:1px solid #323648;border-radius:10px;padding:.85rem 1rem;text-align:center}
.step-num{width:26px;height:26px;background:#c9960c;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#000;margin:0 auto .5rem}
.step p{font-size:12px;color:#8b90a8;line-height:1.5}
.step strong{color:#e8eaf0}

/* CARD */
.card{background:#1c1f2b;border:1px solid #323648;border-radius:14px;padding:1.5rem}
.card-title{font-size:14px;font-weight:700;color:#c9960c;margin-bottom:1.25rem;display:flex;align-items:center;gap:8px}
.card-title span{font-size:20px}

/* PERIOD */
.field{display:flex;flex-direction:column;gap:5px;margin-bottom:1rem}
.field label{font-size:12px;color:#8b90a8;font-weight:500}
input[type=month]{background:#252838;border:1px solid #323648;border-radius:8px;padding:9px 12px;color:#e8eaf0;font-size:13px;font-family:'Tajawal',sans-serif;width:100%;outline:none}
input[type=month]:focus{border-color:#c9960c}

/* DROP ZONE */
.dz{border:2px dashed #323648;border-radius:12px;padding:2rem 1rem;text-align:center;cursor:pointer;transition:.2s;background:#13161f}
.dz:hover,.dz.drag{border-color:#c9960c;background:rgba(201,150,12,.05)}
.dz-icon{font-size:36px;margin-bottom:.5rem}
.dz h3{font-size:14px;font-weight:600;margin-bottom:5px}
.dz p{font-size:12px;color:#8b90a8;line-height:1.7}

/* SLOTS */
.slots{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:1rem}
.slot{background:#252838;border:1px solid #323648;border-radius:8px;padding:9px 12px;display:flex;align-items:center;gap:8px;font-size:12px;transition:.2s}
.slot.ok{border-color:#22c87a;background:rgba(34,200,122,.08)}
.slot-name{flex:1;color:#8b90a8;font-weight:500}
.slot.ok .slot-name{color:#22c87a}
.slot-check{color:#22c87a;font-weight:700;font-size:14px}
.slot-icon{font-size:16px;flex-shrink:0}

/* PROGRESS */
.prog-wrap{display:none;margin-top:1rem}
.prog-header{display:flex;justify-content:space-between;font-size:12px;color:#8b90a8;margin-bottom:5px}
.prog-bg{background:#252838;border-radius:4px;height:8px;overflow:hidden}
.prog-bar{height:100%;background:linear-gradient(90deg,#8b6508,#c9960c);border-radius:4px;transition:width .4s;width:0}

/* RESULT BOX */
.result-box{display:none;background:#0a1f0e;border:1px solid #22c87a;border-radius:10px;padding:1rem 1.25rem;margin-top:1rem}
.result-box h3{font-size:13px;font-weight:700;color:#22c87a;margin-bottom:.5rem}
.result-row{display:flex;justify-content:space-between;font-size:12px;color:#8b90a8;padding:4px 0;border-bottom:1px solid rgba(34,200,122,.15)}
.result-row:last-child{border:none}
.result-val{color:#e8eaf0;font-weight:600}

/* BUTTONS */
.btn-main{width:100%;background:linear-gradient(135deg,#8b6508,#c9960c);color:#fff;border:none;border-radius:10px;padding:13px;font-size:14px;font-weight:700;cursor:pointer;font-family:'Tajawal',sans-serif;transition:.2s;margin-top:1rem;display:flex;align-items:center;justify-content:center;gap:8px}
.btn-main:hover{opacity:.9}
.btn-main:disabled{background:#252838;color:#555a70;cursor:not-allowed}

/* GITHUB SECTION */
.gh-section{border-top:1px solid #323648;margin-top:1.25rem;padding-top:1.25rem}
.gh-toggle{display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none}
.gh-toggle h3{font-size:13px;font-weight:600;color:#8b90a8}
.gh-toggle span{font-size:11px;color:#c9960c;font-weight:600}
.gh-fields{display:none;margin-top:1rem;display:grid;gap:.75rem}
.gh-fields.open{display:grid}
input[type=text],input[type=password]{background:#252838;border:1px solid #323648;border-radius:8px;padding:9px 12px;color:#e8eaf0;font-size:13px;font-family:'Tajawal',sans-serif;width:100%;outline:none}
input[type=text]:focus,input[type=password]:focus{border-color:#c9960c}
.inp-label{font-size:11px;color:#8b90a8;margin-bottom:4px;display:block}

/* GUIDE */
.guide{background:#13161f;border:1px solid #323648;border-radius:10px;padding:1.1rem 1.25rem}
.guide-title{font-size:13px;font-weight:700;color:#c9960c;margin-bottom:.75rem}
.guide-step{display:flex;gap:10px;margin-bottom:.65rem;align-items:flex-start}
.guide-step:last-child{margin-bottom:0}
.gs-num{background:#c9960c;color:#000;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;margin-top:1px}
.gs-txt{font-size:12px;color:#8b90a8;line-height:1.6}
.gs-txt strong{color:#e8eaf0}
.gs-txt code{background:#252838;padding:1px 5px;border-radius:4px;font-size:11px;color:#c9960c}

/* LOG */
#log{background:#0f1117;border-radius:8px;padding:.75rem 1rem;font-size:12px;color:#8b90a8;line-height:1.9;max-height:160px;overflow-y:auto;display:none;border:1px solid #323648;margin-top:.75rem;font-family:monospace}
.log-ok{color:#22c87a}
.log-err{color:#ff6b6b}
.log-info{color:#c9960c}

/* STATUS BADGE */
.status{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600}
.status.wait{background:rgba(139,144,168,.1);color:#8b90a8}
.status.working{background:rgba(201,150,12,.1);color:#c9960c}
.status.done{background:rgba(34,200,122,.1);color:#22c87a}
.status.error{background:rgba(255,107,107,.1);color:#ff6b6b}
</style>
</head>
<body>
<div class="wrap">

  <!-- HEADER -->
  <div class="header">
    <div class="diamond"></div>
    <div>
      <h1>وهج الماسة — أداة تحديث التقارير الشهرية</h1>
      <p>المدير المالي: أكرم الأحبابي &nbsp;|&nbsp; a.mahdi@wahajalmassa.com &nbsp;|&nbsp; 07812071698</p>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <div class="steps">
    <div class="step"><div class="step-num">1</div><p>ارفع <strong>ملفات Excel</strong> الشهرية هنا</p></div>
    <div class="step"><div class="step-num">2</div><p>اضغط <strong>تحويل وتصدير</strong> لتحميل data.json</p></div>
    <div class="step"><div class="step-num">3</div><p>ارفع <strong>data.json</strong> على GitHub</p></div>
  </div>

  <!-- MAIN CARD -->
  <div class="card">
    <div class="card-title"><span>📁</span> رفع ملفات Excel</div>

    <!-- Period -->
    <div class="field">
      <label>فترة التقرير (الشهر والسنة)</label>
      <input type="month" id="period">
    </div>

    <!-- Drop Zone -->
    <div class="dz" id="dz" onclick="document.getElementById('fi').click()">
      <div class="dz-icon">📂</div>
      <h3>اسحب الملفات هنا أو اضغط للاختيار</h3>
      <p>
        يقبل ملفات <strong>Excel .xlsx</strong><br>
        الملخص التنفيذي — الربح والخسارة — الميزانية — ميزان المراجعة — التدفقات النقدية<br>
        <em style="color:#555a70">يمكن رفع ملف واحد أو الخمسة معاً</em>
      </p>
      <input type="file" id="fi" accept=".xlsx" multiple style="display:none" onchange="handleFiles(this.files)">
    </div>

    <!-- File Slots -->
    <div class="slots">
      <div class="slot" id="sl-s"><span class="slot-icon">📋</span><span class="slot-name">الملخص التنفيذي</span><span class="slot-check" id="ck-s"></span></div>
      <div class="slot" id="sl-p"><span class="slot-icon">📈</span><span class="slot-name">الربح والخسارة</span><span class="slot-check" id="ck-p"></span></div>
      <div class="slot" id="sl-b"><span class="slot-icon">⚖️</span><span class="slot-name">الميزانية العمومية</span><span class="slot-check" id="ck-b"></span></div>
      <div class="slot" id="sl-t"><span class="slot-icon">📑</span><span class="slot-name">ميزان المراجعة</span><span class="slot-check" id="ck-t"></span></div>
      <div class="slot" id="sl-c"><span class="slot-icon">💵</span><span class="slot-name">التدفقات النقدية</span><span class="slot-check" id="ck-c"></span></div>
    </div>

    <!-- Progress -->
    <div class="prog-wrap" id="prog-wrap">
      <div class="prog-header"><span id="prog-lbl">جاري المعالجة...</span><span id="prog-pct">0%</span></div>
      <div class="prog-bg"><div class="prog-bar" id="prog-bar"></div></div>
    </div>

    <!-- Result Summary -->
    <div class="result-box" id="result-box">
      <h3>✓ تم تحويل الملفات بنجاح</h3>
      <div class="result-row"><span>الفترة</span><span class="result-val" id="r-period">—</span></div>
      <div class="result-row"><span>الملفات المحوّلة</span><span class="result-val" id="r-files">—</span></div>
      <div class="result-row"><span>صافي الربح</span><span class="result-val" id="r-profit">—</span></div>
      <div class="result-row"><span>إجمالي الأصول</span><span class="result-val" id="r-assets">—</span></div>
    </div>

    <!-- MAIN BUTTON -->
    <button class="btn-main" id="btn-convert" disabled onclick="convertAndDownload()">
      ⬇ تحويل وتصدير data.json
    </button>

    <!-- GitHub Direct Upload -->
    <div class="gh-section">
      <div class="gh-toggle" onclick="toggleGH()">
        <h3>🚀 رفع مباشر على GitHub (اختياري)</h3>
        <span id="gh-toggle-lbl">▼ إظهار</span>
      </div>
      <div class="gh-fields" id="gh-fields">
        <div>
          <label class="inp-label">GitHub Token (ghp_...)</label>
          <input type="password" id="gh-token" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx">
        </div>
        <div>
          <label class="inp-label">اسم المستخدم / المستودع</label>
          <input type="text" id="gh-repo" placeholder="wahajalmassa001-dotcom/-">
        </div>
        <button class="btn-main" id="btn-upload" disabled onclick="uploadToGitHub()" style="margin-top:0;background:linear-gradient(135deg,#0d3d72,#1a5fa8)">
          🚀 رفع مباشرة على GitHub
        </button>
      </div>
    </div>

    <!-- Log -->
    <div id="log"></div>
  </div>

  <!-- GUIDE -->
  <div class="guide">
    <div class="guide-title">📖 دليل الاستخدام الشهري</div>

    <div class="guide-step">
      <div class="gs-num">1</div>
      <div class="gs-txt">ارفع ملفات Excel الشهرية في الأعلى (يكفي الملفات المتوفرة)</div>
    </div>
    <div class="guide-step">
      <div class="gs-num">2</div>
      <div class="gs-txt">اضغط <strong>"تحويل وتصدير data.json"</strong> — سيُحمَّل الملف تلقائياً</div>
    </div>
    <div class="guide-step">
      <div class="gs-num">3</div>
      <div class="gs-txt">
        افتح <strong>github.com/wahajalmassa001-dotcom/-</strong>
        → مجلد <code>data</code> → اضغط <strong>Add file → Upload files</strong>
      </div>
    </div>
    <div class="guide-step">
      <div class="gs-num">4</div>
      <div class="gs-txt">اسحب <code>data.json</code> الجديد وأفلته → اضغط <strong>Commit changes</strong></div>
    </div>
    <div class="guide-step">
      <div class="gs-num">5</div>
      <div class="gs-txt">
        ✅ بعد <strong>60 ثانية</strong> يتحدث الرابط تلقائياً لدى جميع المستخدمين:<br>
        <code>wahajalmassa001-dotcom.github.io/-</code>
      </div>
    </div>
  </div>

</div>

<script>
// ══════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════
const parsed = {s:null, p:null, b:null, t:null, c:null};
let builtJSON = null;

// Set current month as default
const now = new Date();
document.getElementById('period').value =
  now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0');

// Load saved GitHub config
['gh-token','gh-repo'].forEach(id => {
  const saved = localStorage.getItem('wm_'+id);
  if(saved) document.getElementById(id).value = saved;
  document.getElementById(id).addEventListener('change', e => {
    localStorage.setItem('wm_'+id, e.target.value);
  });
});

// ══════════════════════════════════════════════
//  DRAG & DROP
// ══════════════════════════════════════════════
const dz = document.getElementById('dz');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag'); });
dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
dz.addEventListener('drop', e => { e.preventDefault(); dz.classList.remove('drag'); handleFiles(e.dataTransfer.files); });

// ══════════════════════════════════════════════
//  PROGRESS & LOG
// ══════════════════════════════════════════════
function setProgress(pct, lbl) {
  document.getElementById('prog-wrap').style.display = 'block';
  document.getElementById('prog-bar').style.width = pct + '%';
  document.getElementById('prog-pct').textContent = Math.round(pct) + '%';
  document.getElementById('prog-lbl').textContent = lbl;
}

function addLog(msg, type='info') {
  const el = document.getElementById('log');
  el.style.display = 'block';
  const time = new Date().toLocaleTimeString('ar');
  el.innerHTML += `<div class="log-${type}">[${time}] ${msg}</div>`;
  el.scrollTop = el.scrollHeight;
}

// ══════════════════════════════════════════════
//  FILE TYPE DETECTION
// ══════════════════════════════════════════════
function detectType(name, wb) {
  const n = name.toLowerCase();
  const sheets = wb.SheetNames.join(' ').toLowerCase();

  // By filename
  if(n.includes('ملخص') || n.includes('summary'))   return 's';
  if(n.includes('ربح')  || n.includes('pnl') || n.includes('profit')) return 'p';
  if(n.includes('ميزانية') || n.includes('balance')) return 'b';
  if(n.includes('مراجعة') || n.includes('trial'))    return 't';
  if(n.includes('تدفق') || n.includes('cash') || n.includes('flow')) return 'c';

  // By sheet names
  if(sheets.includes('ملخص'))    return 's';
  if(sheets.includes('ربح'))     return 'p';
  if(sheets.includes('ميزانية')) return 'b';
  if(sheets.includes('مراجعة'))  return 't';
  if(sheets.includes('تدفق') || sheets.includes('cash')) return 'c';

  // By content
  try {
    const csv = XLSX.utils.sheet_to_csv(wb.Sheets[wb.SheetNames[0]]);
    if(csv.includes('صافي الأصول') || csv.includes('الفائض النقدي') || csv.includes('متوسط أيام')) return 's';
    if(csv.includes('إجمالي الربح') && !csv.includes('الأصول المتداولة')) return 'p';
    if(csv.includes('الأصول المتداولة') && csv.includes('رأس المال'))     return 'b';
    if(csv.includes('الرصيد الافتتاحي') || csv.includes('اسم الحساب'))    return 't';
    if(csv.includes('أنشطة التشغيل') || csv.includes('تدفقات'))           return 'c';
  } catch(e) {}

  return null;
}

// ══════════════════════════════════════════════
//  HANDLE FILES
// ══════════════════════════════════════════════
function handleFiles(files) {
  const arr = Array.from(files);
  let done = 0;
  setProgress(0, 'جاري قراءة الملفات...');
  document.getElementById('result-box').style.display = 'none';

  arr.forEach(f => {
    const reader = new FileReader();
    reader.onload = e => {
      try {
        const wb = XLSX.read(e.target.result, {type:'array'});
        const key = detectType(f.name, wb);
        if(key) {
          parsed[key] = wb;
          document.getElementById('sl-'+key).classList.add('ok');
          document.getElementById('ck-'+key).textContent = '✓';
          addLog(`✓ ${f.name} → ${({s:'ملخص',p:'ربح/خسارة',b:'ميزانية',t:'ميزان مراجعة',c:'تدفقات'})[key]}`, 'ok');
        } else {
          addLog(`⚠ لم يُتعرف على: ${f.name}`, 'err');
        }
      } catch(err) {
        addLog(`❌ خطأ في قراءة: ${f.name} — ${err.message}`, 'err');
      }
      done++;
      setProgress(done/arr.length * 40, `قُرئ ${done} من ${arr.length} ملفات...`);
      if(done === arr.length) {
        const any = Object.values(parsed).some(v => v !== null);
        document.getElementById('btn-convert').disabled = !any;
        document.getElementById('btn-upload').disabled = !any;
        setProgress(40, any ? '✓ جاهز للتحويل — اضغط الزر أدناه' : 'لم يُتعرف على أي ملف');
      }
    };
    reader.readAsArrayBuffer(f);
  });
}

// ══════════════════════════════════════════════
//  EXCEL PARSERS
// ══════════════════════════════════════════════
function getRows(wb, idx=0) {
  return XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[idx]], {header:1, defval:null});
}

function getPeriod(rows) {
  for(const r of rows)
    for(const c of r)
      if(c && /\d{4}/.test(String(c)) && String(c).length < 30)
        return String(c).trim();
  return '';
}

function findValue(rows, label) {
  for(const r of rows)
    for(let i = 0; i < r.length; i++)
      if(r[i] && String(r[i]).includes(label))
        for(let j = i+1; j < r.length; j++) {
          const v = parseFloat(r[j]);
          if(!isNaN(v)) return v;
        }
  return null;
}

// ══════════════════════════════════════════════
//  BUILD JSON
// ══════════════════════════════════════════════
function buildJSON() {
  const periodInput = document.getElementById('period').value;
  const [yr, mn] = periodInput.split('-');
  const months = ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
  const displayPeriod = `${months[parseInt(mn)-1]} ${yr}`;

  const out = {
    meta: {
      period: displayPeriod,
      raw_period: periodInput,
      generated: new Date().toISOString(),
      generated_by: 'أكرم الأحبابي — المدير المالي'
    },
    summary:{}, pnl:{}, balance:{}, trial:[], cashflow:{}
  };

  // ① SUMMARY
  if(parsed.s) {
    const r = getRows(parsed.s);
    const per = getPeriod(r); if(per) out.meta.summary_period = per;
    ['الأرباح النقدية','المبلغ المُنفَق','الفائض النقدي','رصيد الإقفال البنكي',
     'الدخل','تكاليف الإيرادات','إجمالي الربح','النفقات','صافي الربح',
     'المدينين','الدائنون','صافي الأصول','هامش الربح الإجمالي',
     'صافي هامش الربح','العائد على الاستثمار','متوسط أيام المدينين',
     'متوسط أيام الدائنين','توقعات النقد قصيرة الأجل',
     'نسبة الأصول المتداولة إلى الالتزامات'
    ].forEach(k => { const v = findValue(r,k); if(v !== null) out.summary[k] = v; });
  }

  // ② PNL
  if(parsed.p) {
    const r = getRows(parsed.p);
    const per = getPeriod(r); if(per) out.meta.pnl_period = per;
    ['الإيرادات','تكاليف الإيرادات','إجمالي الربح','النفقات',
     'الدخل التشغيلي','دخل آخر','إهلاك','صافي الربح'
    ].forEach(k => { const v = findValue(r,k); if(v !== null) out.pnl[k] = v; });
  }

  // ③ BALANCE
  if(parsed.b) {
    const r = getRows(parsed.b);
    const per = getPeriod(r); if(per) out.meta.balance_period = per;
    for(const row of r) {
      if(!row[0] || typeof row[0] !== 'string') continue;
      const lbl = row[0].trim();
      let val = parseFloat(row[1]);
      if(isNaN(val)) val = parseFloat(row[2]);
      if(isNaN(val)) continue;
      const balanceKeys = [
        'إجمالي الأصول','الأصول المتداولة','الحسابات البنكية',
        'المدينين','أصول متداولة أخرى','المصاريف المدفوعة',
        'الأصول غير المتداولة','إجمالي الالتزامات','الالتزامات الجارية',
        'الدائنون','رأس المال','أرباح غير مخصصة','الأرباح المحتجزة'
      ];
      balanceKeys.forEach(k => { if(lbl.includes(k.slice(0,5))) out.balance[k] = val; });
    }
    // حساب الأصول الأخرى
    out.balance['أصول متداولة أخرى'] =
      (out.balance['الأصول المتداولة']||0)
      - (out.balance['الحسابات البنكية']||0)
      - (out.balance['المدينين']||0)
      - (out.balance['المصاريف المدفوعة']||0);
  }

  // ④ TRIAL BALANCE
  if(parsed.t) {
    const r = getRows(parsed.t);
    const per = getPeriod(r); if(per) out.meta.trial_period = per;
    let headerIdx = -1;
    for(let i = 0; i < r.length; i++) {
      if(r[i] && r[i].some(c => c && String(c).includes('اسم الحساب'))) { headerIdx = i; break; }
    }
    if(headerIdx < 0) {
      // fallback: find first row with 6+ non-null values
      for(let i = 0; i < r.length; i++) {
        if(r[i] && r[i].filter(c => c !== null).length >= 6) { headerIdx = i; break; }
      }
    }
    if(headerIdx >= 0) {
      for(let i = headerIdx+1; i < r.length; i++) {
        const row = r[i]; if(!row || !row[1]) continue;
        const n = x => { const v = parseFloat(x); return isNaN(v) ? 0 : v; };
        out.trial.push({
          code: String(row[0]||''), name: String(row[1]).trim(),
          openDr: n(row[2]), openCr: n(row[3]),
          movDr:  n(row[4]), movCr:  n(row[5]),
          closeDr:n(row[6]), closeCr:n(row[7])
        });
      }
    }
  }

  // ⑤ CASHFLOW
  if(parsed.c) {
    const r = getRows(parsed.c);
    const per = getPeriod(r); if(per) out.meta.cashflow_period = per;

    // خريطة المرونة: كل مفتاح له قائمة تسميات بديلة للبحث
    const cfMap = {
      'صافي الربح':                    ['صافي الربح','net profit','net income','ربح صافي'],
      'الإهلاك والاستهلاك':            ['الإهلاك والاستهلاك','الإهلاك','استهلاك','depreciation','إهلاك'],
      'التغير في المدينين':            ['التغير في المدينين','المدينين','تغير المدينين','receivables','حسابات القبض'],
      'التغير في المخزون':             ['التغير في المخزون','المخزون','تغير المخزون','inventory','بضاعة'],
      'التغير في الدائنون':            ['التغير في الدائنون','التغير في الدائنين','الدائنون','تغير الدائنين','payables','حسابات الدفع'],
      'التغير في الالتزامات الجارية':  ['التغير في الالتزامات الجارية','الالتزامات الجارية','تغير الالتزامات','current liabilities'],
      'شراء أصول ثابتة':               ['شراء أصول ثابتة','أصول ثابتة','شراء أصول','fixed assets','capital expenditure','capex'],
      'مشاريع رأس المال':              ['مشاريع رأس المال','مشاريع تحت التنفيذ','capital projects','projects'],
      'قروض جديدة':                    ['قروض جديدة','اقتراض','new loans','borrowings','قرض'],
      'سداد قروض':                     ['سداد قروض','سداد','loan repayment','repayment'],
      'توزيعات أرباح':                 ['توزيعات أرباح','توزيع أرباح','dividends','توزيعات'],
      'الرصيد الافتتاحي للنقد':        ['الرصيد الافتتاحي للنقد','رصيد افتتاحي','الرصيد الافتتاحي','opening balance','opening cash','رصيد أول المدة'],
      'الرصيد الختامي للنقد':          ['الرصيد الختامي للنقد','رصيد ختامي','الرصيد الختامي','closing balance','closing cash','رصيد آخر المدة','رصيد نهاية الفترة']
    };

    // دالة بحث مرن
    function findFlexible(rows, aliases) {
      for(const alias of aliases) {
        const v = findValue(rows, alias);
        if(v !== null) return v;
      }
      return null;
    }

    Object.entries(cfMap).forEach(([key, aliases]) => {
      const v = findFlexible(r, aliases);
      if(v !== null) out.cashflow[key] = v;
    });

    // إذا لم يجد صافي الربح — خذه من PNL
    if(!out.cashflow['صافي الربح'] && out.pnl['صافي الربح'])
      out.cashflow['صافي الربح'] = out.pnl['صافي الربح'];

    // إذا لم يجد الإهلاك — خذه من PNL
    if(!out.cashflow['الإهلاك والاستهلاك'] && out.pnl['إهلاك'])
      out.cashflow['الإهلاك والاستهلاك'] = out.pnl['إهلاك'];

    // طباعة ما تم إيجاده للتشخيص
    console.log('Cashflow parsed:', JSON.stringify(out.cashflow));
    addLog('📊 التدفقات: وجدت ' + Object.keys(out.cashflow).length + ' بند', 'ok');
  }

  return out;
}

// ══════════════════════════════════════════════
//  CONVERT & DOWNLOAD
// ══════════════════════════════════════════════
function convertAndDownload() {
  setProgress(50, 'جاري تحويل البيانات...');
  document.getElementById('log').style.display = 'block';
  addLog('⏳ بدء عملية التحويل...', 'info');

  try {
    builtJSON = buildJSON();
    setProgress(85, 'جاري إنشاء الملف...');

    // Show result summary
    const box = document.getElementById('result-box');
    const files = Object.entries(parsed).filter(([,v])=>v).map(([k])=>({s:'ملخص',p:'ربح/خسارة',b:'ميزانية',t:'مراجعة',c:'تدفقات'})[k]);
    document.getElementById('r-period').textContent  = builtJSON.meta.period;
    document.getElementById('r-files').textContent   = files.join(' | ');
    document.getElementById('r-profit').textContent  = builtJSON.pnl['صافي الربح'] ? fmtNum(builtJSON.pnl['صافي الربح'])+' د.ع' : '—';
    document.getElementById('r-assets').textContent  = builtJSON.balance['إجمالي الأصول'] ? fmtNum(builtJSON.balance['إجمالي الأصول'])+' د.ع' : '—';
    box.style.display = 'block';

    // Download
    const blob = new Blob([JSON.stringify(builtJSON, null, 2)], {type:'application/json'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'data.json';
    a.click();

    setProgress(100, '✅ تم التحويل — data.json جاهز للرفع');
    addLog(`✅ تم تحويل ${files.length} ملف بنجاح`, 'ok');
    addLog(`📅 الفترة: ${builtJSON.meta.period}`, 'info');
    addLog(`📁 احفظ data.json ثم ارفعه على GitHub في مجلد data/`, 'info');

  } catch(err) {
    setProgress(0, '❌ خطأ أثناء التحويل');
    addLog(`❌ خطأ: ${err.message}`, 'err');
    console.error(err);
  }
}

// ══════════════════════════════════════════════
//  UPLOAD TO GITHUB DIRECTLY
// ══════════════════════════════════════════════
async function uploadToGitHub() {
  if(!builtJSON) {
    // Build first
    try { builtJSON = buildJSON(); }
    catch(e) { addLog('❌ خطأ في بناء الملف: '+e.message,'err'); return; }
  }

  const token = document.getElementById('gh-token').value.trim();
  const repo  = document.getElementById('gh-repo').value.trim();

  if(!token || !repo) {
    addLog('⚠ يرجى إدخال GitHub Token واسم المستودع', 'err');
    document.getElementById('gh-fields').classList.add('open');
    return;
  }

  setProgress(60, 'جاري الرفع على GitHub...');
  addLog('⏳ جاري الاتصال بـ GitHub...', 'info');

  const apiUrl = `https://api.github.com/repos/${repo}/contents/data/data.json`;
  const content = btoa(unescape(encodeURIComponent(JSON.stringify(builtJSON, null, 2))));

  try {
    // Get current SHA for update
    let sha = null;
    const get = await fetch(apiUrl, {
      headers: {'Authorization':'token '+token, 'Accept':'application/vnd.github.v3+json'}
    });
    if(get.ok) { const d = await get.json(); sha = d.sha; }

    const body = {
      message: `تحديث التقارير المالية — ${builtJSON.meta.period}`,
      content,
      ...(sha ? {sha} : {})
    };

    setProgress(80, 'جاري رفع الملف...');
    const res = await fetch(apiUrl, {
      method: 'PUT',
      headers: {'Authorization':'token '+token,'Content-Type':'application/json','Accept':'application/vnd.github.v3+json'},
      body: JSON.stringify(body)
    });

    if(res.ok) {
      setProgress(100, '✅ تم الرفع — الموقع سيتحدث خلال 60 ثانية');
      addLog(`✅ تم رفع data.json على GitHub بنجاح!`, 'ok');
      addLog(`⏱ سيتحدث الرابط خلال 60 ثانية`, 'info');
      addLog(`🔗 wahajalmassa001-dotcom.github.io/-`, 'info');
    } else {
      const err = await res.json();
      addLog(`❌ فشل الرفع: ${err.message}`, 'err');
      setProgress(0, '❌ فشل الرفع');
    }
  } catch(e) {
    addLog(`❌ خطأ في الاتصال: ${e.message}`, 'err');
    setProgress(0, '❌ خطأ في الاتصال');
  }
}

// ══════════════════════════════════════════════
//  HELPERS
// ══════════════════════════════════════════════
function fmtNum(n) {
  if(!n || isNaN(n)) return '—';
  const abs = Math.abs(n);
  if(abs >= 1e9) return (n/1e9).toFixed(3)+' مليار';
  if(abs >= 1e6) return (n/1e6).toFixed(3)+' مليون';
  return n.toLocaleString('ar-IQ');
}

let ghOpen = false;
function toggleGH() {
  ghOpen = !ghOpen;
  document.getElementById('gh-fields').classList.toggle('open', ghOpen);
  document.getElementById('gh-toggle-lbl').textContent = ghOpen ? '▲ إخفاء' : '▼ إظهار';
}
</script>
